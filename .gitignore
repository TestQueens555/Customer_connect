node_modules/

# ── Playwright / Automation report output (auto-generated, not committed) ──
reports/screenshots/
reports/html-report/
reports/monocart/
reports/test-results.json
!reports/.gitkeep
test-results/

# ── Allure (auto-generated, not committed) ────────────────────────────────
allure-results/*
allure-report/
!allure-results/.gitkeep

# ── Test Execution Reports (COMMITTED TO GIT) ─────────────────────────────
# Feature Reports and Daily Reports Excel files ARE tracked — do NOT ignore
!Test Execution Report/
!Test Execution Report/**
!Test Execution Report/Feature Reports/
!Test Execution Report/Feature Reports/**
!Test Execution Report/Daily Reports/
!Test Execution Report/Daily Reports/**

# ── Media / binary generated files ───────────────────────────────────────
*.webm
*.zip

# ── Env ───────────────────────────────────────────────────────────────────
.env
